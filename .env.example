# --- Required ---
# Use long random strings (32+ bytes recommended). Minimum 16 bytes enforced.
JWT_SECRET=change-me-to-a-long-random-string-please-32+
HMAC_SAVE_SECRET=change-me-save-secret-32+
HMAC_LOAD_SECRET=change-me-load-secret-32+

# --- Common ---
DB_PATH=./data/vrc.db
API_ADDR=:8100
BASE_URL=http://localhost:8100
TICKET_TTL=5m
CHALLENGE_RATE_TTL=1m

# --- Discord Bot (optional; required only when running cmd/bot) ---
BOT_TOKEN=
BOT_GUILD_ID=
ADMIN_USER_IDS=
