# --- Required ---
# Use long random strings (32+ bytes recommended). Minimum 16 bytes enforced.
JWT_SECRET=change-me-to-a-long-random-string-please-32+
HMAC_SAVE_SECRET=change-me-save-secret-32+
HMAC_LOAD_SECRET=change-me-load-secret-32+

# Discord OAuth2 application credentials (https://discord.com/developers/applications)
# Register the OAuth2 redirect URI as <BASE_URL>/auth/callback (or whatever
# OAUTH_REDIRECT_URL you set explicitly).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Common ---
DB_PATH=./data/vrc.db
API_ADDR=:8100
BASE_URL=http://localhost:8100

# Optional. Defaults to <BASE_URL>/auth/callback when empty.
OAUTH_REDIRECT_URL=

# How long an /auth/start state is valid before its callback must arrive.
OAUTH_STATE_TTL=5m

# How long the portal session token is valid after OAuth completes.
SESSION_TTL=15m

# --- Development only: mock OAuth ---
# OAUTH_MODE=discord (default) goes through real Discord OAuth.
# OAUTH_MODE=mock replaces the Discord redirect with an internal
# /auth/mock-login page. Optional fake_discord_id / fake_username query
# strings on /auth/start override the per-request defaults (random
# snowflake / proposed VRChat name). DISCORD_CLIENT_ID/SECRET become
# unused. Never enable in production.
OAUTH_MODE=discord

